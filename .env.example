# Copy this file to `.env.local` (git-ignored) and fill in real values.

# Google OAuth 2.0 Web client ID from Google Cloud Console.
# This value is public and safe to expose in the built app.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ID of the Google Sheet that stores the transactions.
# It's the long string in the sheet URL: /spreadsheets/d/<THIS PART>/edit
VITE_SPREADSHEET_ID=your-spreadsheet-id
